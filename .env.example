# API base URL of the frostique service-application
VITE_API_BASE_URL=http://localhost:3000/api/v1

# Tenant this white-label build serves (tenant schema name, e.g. arbaj_yakub_ansari)
VITE_TENANT_ID=

# Google OAuth client id (customer login). Leave blank for backend dev fallback.
VITE_GOOGLE_CLIENT_ID=
